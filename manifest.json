{
  "manifest_version": 3,
  "name": "MPVise",
  "version": "3.1.0",
  "description": "Play any web video in mpv. Right-click → Play with MPVise.",
  "permissions": [
    "activeTab",
    "notifications",
    "contextMenus",
    "tabs",
    "webRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16":  "icons/play-button-16.png",
      "32":  "icons/play-button-32.png",
      "48":  "icons/play-button-48.png",
      "128": "icons/play-button-128.png"
    },
    "default_title": "Play with MPVise",
    "default_popup": ""
  },
  "icons": {
    "16":  "icons/play-button-16.png",
    "32":  "icons/play-button-32.png",
    "48":  "icons/play-button-48.png",
    "128": "icons/play-button-128.png"
  },
  "minimum_chrome_version": "108"
}
