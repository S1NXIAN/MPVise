# CLI Entry Point
# ═══════════════════════════════════════════════════════════════════════════

if __name__ == "__main__":
    # Handle help flags before argparse
    if any(arg in sys.argv for arg in ["-h", "--help", "?", "-?"]):
        print(HELP)
        sys.exit(0)

    # Default: run server if no arguments (but check if already running first)
    if len(sys.argv) == 1:
        pid = get_pid()
        if pid and is_running(pid):
            print(f"Already running (PID {pid})")
            sys.exit(0)
        dep = check_dependencies()
        if dep:
            print(dep)
            sys.exit(1)
        asyncio.run(main())
        sys.exit(0)

    # Flag-based arguments (global)
    parser = argparse.ArgumentParser(
        prog="mpvise",
        description="Play web videos in mpv",
        add_help=False,
        usage="mpvise [-h] [-v] [-S T s R l r p] [--help|--version|--start|--stop|--status|--restart|--logs|--run|--ping]"
    )
    parser.add_argument("-h", "--help", action="store_true", help="Show detailed manual")
    parser.add_argument("-v", "--version", action="store_true", help="Show version")
    parser.add_argument("-S", "--start", action="store_true", help="Start daemon")
    parser.add_argument("-T", "--stop", action="store_true", help="Stop daemon")
    parser.add_argument("-s", "--status", action="store_true", help="Check status")
    parser.add_argument("-R", "--restart", action="store_true", help="Restart daemon")
    parser.add_argument("-l", "--logs", action="store_true", help="View logs")
    parser.add_argument("-r", "--run", action="store_true", help="Run in foreground")
    parser.add_argument("-p", "--ping", action="store_true", help="Health check")
    parser.add_argument("-c", "--clear-logs", action="store_true", help="Clear daemon logs")

    args = parser.parse_args()

    # Version handler (global - check first)
    if args.version:
        print(f"mpvise v{VERSION}")
        sys.exit(0)

    # Help handler
    if args.help:
        print(HELP)
        sys.exit(0)

    # Command handlers (first wins)
    if args.start:
        asyncio.run(start_daemon())
    elif args.stop:
        asyncio.run(stop_daemon())
    elif args.status:
        pid = get_pid()
        if pid and is_running(pid):
            print(f"Running (PID {pid})")
        else:
            print("Stopped")
    elif args.restart:
        async def _restart():
            await stop_daemon()
            await asyncio.sleep(0.5)
            await start_daemon()
        asyncio.run(_restart())
    elif args.logs:
        if LOG_FILE.exists():
            print(LOG_FILE.read_text()[-2000:])
    elif args.ping:
        import socket
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(1)
        print("Running" if sock.connect_ex(("127.0.0.1", PORT)) == 0 else "Stopped")
    elif args.clear_logs:
        if LOG_FILE.exists():
            LOG_FILE.write_text("")
            print("Logs cleared")
        else:
            print("No logs to clear")
    elif args.run:
        dep = check_dependencies()
        if dep:
            print(dep)
            sys.exit(1)
        asyncio.run(main())
    else:
        # Default: run server (for extension compatibility)
        dep = check_dependencies()
        if dep:
            print(dep)
            sys.exit(1)
        asyncio.run(main())