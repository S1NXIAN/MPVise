def get_display_env():
    """Heuristic to find display variables for Wayland/X11"""
    env = {}
    for var in ["DISPLAY", "WAYLAND_DISPLAY", "XDG_RUNTIME_DIR", "DBUS_SESSION_BUS_ADDRESS"]:
        if var in os.environ:
            env[var] = os.environ[var]
    return env

def get_mpv_env():
    """Get environment with display vars for mpv"""
    env = {**os.environ}
    disp = get_display_env()
    if disp:
        env.update(disp)
    return env

async def handle_play(req):
    from aiohttp import web
    
    resp = web.StreamResponse(status=200, reason='OK', headers={'Content-Type': 'application/x-ndjson'})
    await resp.prepare(req)

    async def send_event(data):
        await resp.write(json.dumps(data).encode() + b"\n")

    try:
        data = await req.json()
    except:
        await send_event({"error": "bad request"})
        return resp

    url = (data.get("url") or "").strip()
    direct = data.get("direct", False)
    hint = data.get("hint")

    if not url.startswith("http"):
        await send_event({"error": "invalid url"})
        return resp

    log(f"PLAY: {url[:60]} (hint: {hint})")

    browser = None
    if not direct:
        browser = await detect_and_test_browser(url, progress_cb=send_event, hint=hint)
        if not browser:
            await send_event({"error": "No playable video found. (Tried guest mode + configured browsers)"})
            return

    cmd = ["mpv"]
    if CONF["mpv_socket"]:
        cmd.append(f"--input-ipc-server={CONF['mpv_socket']}")
    if CONF["ytdlp_format"]:
        cmd.append(f"--ytdl-format={CONF['ytdlp_format']}")
    if CONF["mpv_args"]:
        cmd.extend(CONF["mpv_args"])
    if browser and browser != "guest":
        cmd.append(f"--ytdl-raw-options=cookies-from-browser={browser}")
    cmd.append(url)
    log(f"EXEC: {' '.join(cmd)}")

    try:
        await send_event({"status": "launching", "browser": browser})
        proc = await asyncio.create_subprocess_exec(
            *cmd,
            stdin=asyncio.subprocess.DEVNULL,
            stdout=asyncio.subprocess.DEVNULL,
            stderr=asyncio.subprocess.PIPE,
            env=get_mpv_env()
        )
        
        # Non-blocking "Is it still alive?" check
        try:
            # We only wait a short bit for immediate startup crashes
            await asyncio.wait_for(proc.wait(), timeout=1.0)
            if proc.returncode != 0:
                # If it exited, try to read the last error from stderr
                stderr_data = await proc.stderr.read()
                err = stderr_data.decode().strip().split('\n')[-1] if stderr_data else f"Code {proc.returncode}"
                log(f"mpv exited immediately: {err}")
                await send_event({"error": f"mpv failed to start ({err})"})
                return resp
        except asyncio.TimeoutError:
            # Still running! Start a background task to drain stderr so it doesn't deadlock
            async def drain_pipe(stream):
                try:
                    while True:
                        if not await stream.read(8192): break
                except: pass
            asyncio.create_task(drain_pipe(proc.stderr))

        await send_event({"status": "playing", "ok": True, "browser": browser, "direct": direct})
    except FileNotFoundError:
        await send_event({"error": "mpv not found"})
    
    await resp.write_eof()
    return resp

async def main():
    from aiohttp import web

    setup_config()
    log("MPVise started")
    PID_FILE.write_text(str(os.getpid()))

    app = web.Application()
    app.router.add_post("/play", handle_play)
    app.router.add_get("/ping", lambda r: web.json_response({"ok": True}))
    app.router.add_get("/config", lambda r: web.json_response({
        "port": PORT,
        "browsers": CONF["browsers"],
        "mpv_socket": MPV_SOCKET,
    }))

    runner = web.AppRunner(app)
    await runner.setup()
    site = web.TCPSite(runner, "127.0.0.1", PORT)
    await site.start()

    print(f"MPVise running on 127.0.0.1:{PORT}")

    loop = asyncio.get_running_loop()
    stop = loop.create_future()
    for sig in (signal.SIGTERM, signal.SIGINT):
        try:
            loop.add_signal_handler(sig, stop.set_result, sig)
        except NotImplementedError:
            pass

    try:
        await stop
    finally:
        log("Stopped")
        PID_FILE.unlink(missing_ok=True)

