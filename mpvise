# ═══════════════════════════════════════════════════════════════════
# DATA LOADER
# ═══════════════════════════════════════════════════════════════════
def load_internal_defaults():
    path = Path(__file__).parent / "defaults.json"
    if not path.exists():
        # Fallback if file is missing (minimal safety)
        return {"server": {"port": 8765}, "browsers": {"config_map": {}, "cookie_paths": []}}
    return json.loads(path.read_text())

DATA = load_internal_defaults()
VERSION = DATA.get("version")

# ═══════════════════════════════════════════════════════════════════
# CONFIG
# ═══════════════════════════════════════════════════════════════════
HOME = Path.home()
CONFIG_DIR = HOME / ".config" / "mpvise"
PID_FILE = CONFIG_DIR / "daemon.pid"
LOG_FILE = CONFIG_DIR / "daemon.log"
CACHE_FILE = CONFIG_DIR / "browser_cache.json"
CONFIG_FILE = CONFIG_DIR / "mpvise.conf"

def load_config():
    config = DATA["server"].copy()
    config["browsers"] = []
    
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE, "r") as f:
                for line in f:
                    line = line.strip()
                    if not line or line.startswith(("#", ";")):
                        continue
                    if "=" in line:
                        key, val = line.split("=", 1)
                        key, val = key.strip(), val.strip()
                        
                        # Handle shell-style lists: (a, b, c) -> a, b, c
                        val = val.strip("()")
                        
                        if key == "port": 
                            config["port"] = int(val)
                        elif key == "mpv_args": 
                            config["mpv_args"] = val.replace(",", " ").split()
                        elif key == "browsers": 
                            # Clean up double commas and split
                            raw_browsers = val.replace(",,", ",").split(",")
                            config["browsers"] = [b.strip() for b in raw_browsers if b.strip()]
                        else: 
                            config[key] = val
        except Exception as e:
            print(f"Error loading mpvise.conf: {e}")

    # Environment overrides
    if os.environ.get("MPVISE_PORT"): config["port"] = int(os.environ["MPVISE_PORT"])
    if os.environ.get("MPVISE_MPV_SOCKET"): config["mpv_socket"] = os.environ["MPVISE_MPV_SOCKET"]
    if os.environ.get("MPVISE_BROWSERS"): config["browsers"] = [b.strip() for b in os.environ["MPVISE_BROWSERS"].split(",")]
    if os.environ.get("MPVISE_YTDLP_FORMAT"): config["ytdlp_format"] = os.environ["MPVISE_YTDLP_FORMAT"]

    return config

CONF = load_config()
PORT = CONF["port"]
MPV_SOCKET = CONF["mpv_socket"]

# ═══════════════════════════════════════════════════════════════════
# MODULE: Utils
# ═══════════════════════════════════════════════════════════════════

def get_display_env():
    """Auto-detect display environment (Wayland > X11 > None)"""
    if os.environ.get("WAYLAND_DISPLAY"):
        return {"WAYLAND_DISPLAY": os.environ["WAYLAND_DISPLAY"], "XDG_RUNTIME_DIR": os.environ.get("XDG_RUNTIME_DIR", "")}
    if os.environ.get("DISPLAY"):
        return {"DISPLAY": os.environ["DISPLAY"]}
    return None

def detect_distro():
    """Detect Linux distro for package manager"""
    for path in ["/etc/os-release", "/etc/arch-release", "/etc/debian_version", "/etc/fedora-release", "/etc/SuSE-release"]:
        if Path(path).exists():
            content = Path(path).read_text().lower()
            if "arch" in content: return "pacman"
            if "debian" in content or "ubuntu" in content: return "apt"
            if "fedora" in content or "rhel" in content: return "dnf"
            if "sles" in content or "opensuse" in content: return "zypper"
    for cmd in ["pacman", "apt", "dnf", "zypper", "apk"]:
        if subprocess.run(["which", cmd], capture_output=True).returncode == 0:
            return cmd
    return "apt"

def check_dependencies():
    """Check mpv and yt-dlp, return install command if missing"""
    distro = detect_distro()
    pkg_mgr = {
        "pacman": "sudo pacman -S", "apt": "sudo apt install", "dnf": "sudo dnf install",
        "zypper": "sudo zypper in", "apk": "sudo apk add"
    }.get(distro, "sudo apt install")

    mpv = subprocess.run(["which", "mpv"], capture_output=True).returncode
    ytdlp = subprocess.run(["which", "yt-dlp"], capture_output=True).returncode

    if mpv != 0 and ytdlp != 0:
        return f"mpv & yt-dlp not found. Install with: {pkg_mgr} mpv yt-dlp"
    if mpv != 0:
        return f"mpv not found. Install with: {pkg_mgr} mpv"
    if ytdlp != 0:
        return f"yt-dlp not found. Install with: {pkg_mgr} yt-dlp"
    return None

def setup_config():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if not CONFIG_FILE.exists():
        try:
            # Try to copy the template from the repo if it exists
            template = Path(__file__).parent / "mpvise-default.conf"
            if template.exists():
                shutil.copy2(template, CONFIG_FILE)
                print(f"Config initialized: {CONFIG_FILE}")
            else:
                # Fallback to generating a basic text config
                content = "# MPVise Config\n"
                for k, v in DATA["server"].items():
                    if isinstance(v, list): v = " ".join(v) if k == "mpv_args" else ",".join(v)
                    content += f"{k}={v}\n"
                CONFIG_FILE.write_text(content)
                print(f"Generated basic config at {CONFIG_FILE}")
        except Exception as e:
            print(f"Warning: Could not setup mpvise.conf: {e}")

def log(msg):
    LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
    with open(LOG_FILE, "a") as f:
        f.write(f"[{time.strftime('%H:%M:%S')}] {msg}\n")

# ═══════════════════════════════════════════════════════════════════
# MODULE: Browser Detection
# ═══════════════════════════════════════════════════════════════════

def scan_config_browsers(only_allow=None):
    config_dir = Path.home() / ".config"
    found = []
    check_paths = DATA["browsers"]["cookie_paths"]
    
    # Only iterate through browsers the user actually cares about
    for dir_name, browser in DATA["browsers"]["config_map"].items():
        if only_allow and browser not in only_allow:
            continue
            
        base_path = config_dir / dir_name
        if base_path.exists():
            is_valid = False
            for p in check_paths:
                if any(base_path.rglob(p)):
                    is_valid = True
                    break
            if is_valid:
                found.append(browser)
    return found

def get_cached_browser():
    if not CACHE_FILE.exists():
        return None
    try:
        cached = json.loads(CACHE_FILE.read_text())
        current = scan_config_browsers(only_allow=CONF["browsers"])
        if cached.get("browser") in current:
            return cached.get("browser")
        CACHE_FILE.unlink()
    except:
        pass
    return None

def save_browser_cache(browser):
    CACHE_FILE.write_text(json.dumps({"browser": browser, "time": time.time()}))

async def detect_and_test_browser(url, progress_cb=None, hint=None, timeout=5):
    cached = get_cached_browser()
    if cached:
        if progress_cb: await progress_cb({"status": "using_cache", "browser": cached})
        return cached

    # Targeted Scan: Only look for browsers listed in the user's config
    found = scan_config_browsers(only_allow=CONF["browsers"])
    priority = [b for b in CONF["browsers"] if b in found]
    
    # If a hint is provided (active browser), prioritize it
    if hint and hint in priority:
        priority.remove(hint)
        priority.insert(0, hint)

    # Add a "No Cookies" (None) test to the race for public videos
    targets = [None] + priority[:3]
    
    if progress_cb:
        if len(targets) == 1:
            await progress_cb({"status": "resolving_cookies", "browser": "Guest"})
        else:
            await progress_cb({"status": "racing_browsers", "count": len(targets)})

    async def test_one(browser):
        try:
            args = ["yt-dlp", "--list-subs", url]
            if browser:
                args.extend(["--cookies-from-browser", browser])
            
            proc = await asyncio.create_subprocess_exec(
                *args,
                stdout=asyncio.subprocess.DEVNULL, stderr=asyncio.subprocess.DEVNULL
            )
            await asyncio.wait_for(proc.communicate(), timeout=timeout)
            if proc.returncode == 0:
                return browser if browser else "guest"
        except:
            pass
        return False

    # Create tasks for all browsers and wait for the first SUCCESS
    tasks = [asyncio.create_task(test_one(b)) for b in targets]
    
    found_browser = None
    for coro in asyncio.as_completed(tasks):
        res = await coro
        if res is not False:
            found_browser = res
            break
    
    # Cancel remaining tasks
    for t in tasks:
        if not t.done(): t.cancel()
    
    if found_browser:
        if found_browser != "guest":
            save_browser_cache(found_browser)
        return found_browser

    return None

# ═══════════════════════════════════════════════════════════════════════════
# MODULE: Daemon Management
# ═══════════════════════════════════════════════════════════════════

def get_pid():
    if not PID_FILE.exists():
        return None
    try:
        return int(PID_FILE.read_text().strip())
    except:
        return None

def is_port_in_use(port):
    import socket
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        return s.connect_ex(('127.0.0.1', port)) == 0

def is_running(pid=None):
    """Checks if a specific PID is actually active in the process table."""
    if pid is None:
        return False
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False

def start_daemon():
    # Final safety check: block if port is busy or PID is active
    pid = get_pid()
    if (pid and is_running(pid)) or is_port_in_use(PORT):
        print(f"Already running" + (f" (PID {pid})" if pid else f" on port {PORT}"))
        return

    setup_config()
    env = {**os.environ, "PYTHONDONTWRITEBYTECODE": "1"}
    disp = get_display_env()
    if disp:
        env.update(disp)

    proc = subprocess.Popen(
        ["python3", __file__, "-r"],
        env=env,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
        close_fds=True
    )
    PID_FILE.write_text(str(proc.pid))
    print(f"Started (PID {proc.pid})")

async def stop_daemon(silent=False):
    pid = get_pid()
    
    # Priority Recovery: If port is busy, find WHO is using it (ignoring the PID file)
    if is_port_in_use(PORT):
        try:
            res = subprocess.run(["fuser", f"{PORT}/tcp"], capture_output=True, text=True)
            if res.returncode == 0:
                found_pid = int(res.stdout.strip().split()[-1])
                if pid and found_pid != pid:
                    if not silent: print(f"Port {PORT} busy by ghost PID {found_pid}. Overriding.")
                pid = found_pid
        except:
            pass

    if not pid or not is_running(pid):
        if not silent: print("Not running")
        return

    try:
        print(f"Stopping PID {pid}...")
        os.kill(pid, signal.SIGTERM)
        
        # Wait up to 2 seconds for it to exit
        for _ in range(20):
            await asyncio.sleep(0.1)
            if not is_running(pid):
                PID_FILE.unlink(missing_ok=True)
                print("Stopped")
                return
        
        # Still alive? Force it.
        print("Daemon is stubborn. Using SIGKILL...")
        os.kill(pid, signal.SIGKILL)
        await asyncio.sleep(0.2)
        PID_FILE.unlink(missing_ok=True)
        print("Stopped (forced)")
    except Exception as e:
        # If the process is already gone, we can safely clean up
        if not is_running(pid):
            PID_FILE.unlink(missing_ok=True)
            if not is_port_in_use(PORT):
                print("Cleaned up stale PID file.")
            else:
                print(f"Process {pid} is gone, but port {PORT} is still busy.")
        else:
            print(f"Error stopping daemon: {e}")

